---
import Layout from '../../layouts/Layout.astro';
import { projects } from '../../data/projects';

export function getStaticPaths() {
  return projects
    .filter(p => p.type !== 'placeholder')
    .map(p => ({ params: { slug: p.slug }, props: { project: p } }));
}

const { project } = Astro.props;
const label = project.type === 'unity' ? 'Play' : 'Open App';
---

<Layout title={`${project.title} — redmorr`}>
  <a href="/" class="back">← Back</a>

  <article class="project">
    <header class="project-header">
      <span class="tag">{project.type === 'unity' ? 'Unity' : 'Blazor'}</span>
      <h1>{project.title}</h1>
      <p class="description">{project.longDescription}</p>
      {project.jamUrl && (
        <a href={project.jamUrl} target="_blank" rel="noopener noreferrer" class="jam-link">
          View jam page →
        </a>
      )}
      {project.note && (
        <p class="note">📝 {project.note}</p>
      )}
    </header>

    {project.embedUrl ? (
      <div class="embed-wrapper">
        <div class="embed-poster" id="poster">
          {project.thumbnail
            ? <img src={project.thumbnail} alt={project.title} class="poster-img" />
            : <div class="poster-bg" />
          }
          <button class="play-btn" id="play-btn" data-src={project.embedUrl}>
            <span class="play-icon">▶</span>
            {label}
          </button>
        </div>
        <iframe id="embed-frame" class="embed-frame hidden" allowfullscreen></iframe>
      </div>
    ) : project.url ? (
      <a href={project.url} target="_blank" rel="noopener noreferrer" class="external-btn">
        {label} →
      </a>
    ) : null}
  </article>
</Layout>

<script>
  const btn = document.getElementById('play-btn') as HTMLButtonElement | null;
  const poster = document.getElementById('poster') as HTMLElement | null;
  const frame = document.getElementById('embed-frame') as HTMLIFrameElement | null;

  btn?.addEventListener('click', () => {
    const src = btn.dataset.src!;
    frame!.src = src;
    poster!.classList.add('hidden');
    frame!.classList.remove('hidden');
  });
</script>

<style>
  .back {
    display: inline-block;
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-bottom: 2.5rem;
    transition: color 0.15s;
  }

  .back:hover {
    color: var(--text);
  }

  .project {
    max-width: 900px;
  }

  .project-header {
    margin-bottom: 2rem;
  }

  .tag {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .description {
    font-size: 1.05rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  .jam-link {
    display: inline-block;
    margin-top: 0.75rem;
    font-size: 0.9rem;
    color: var(--accent);
    transition: color 0.15s;
  }

  .jam-link:hover {
    color: var(--accent-hover);
  }

  .note {
    margin-top: 0.75rem;
    font-size: 0.85rem;
    color: var(--text-muted);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    padding: 0.6rem 0.85rem;
    border-radius: 4px;
  }

  .embed-wrapper {
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--border);
    position: relative;
  }

  .embed-poster {
    width: 100%;
    height: 100%;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .poster-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .poster-bg {
    position: absolute;
    inset: 0;
    background: #111;
  }

  .play-btn {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--accent);
    color: #fff;
    border: none;
    font-size: 1.1rem;
    font-weight: 600;
    padding: 0.85rem 2.25rem;
    border-radius: 6px;
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
  }

  .play-btn:hover {
    background: var(--accent-hover);
    transform: scale(1.04);
  }

  .play-icon {
    font-size: 0.9rem;
  }

  .embed-frame {
    width: 100%;
    height: 100%;
    border: none;
    display: block;
  }

  .hidden {
    display: none;
  }

  .external-btn {
    display: inline-block;
    background: var(--accent);
    color: #fff;
    font-weight: 600;
    font-size: 1rem;
    padding: 0.75rem 2rem;
    border-radius: 6px;
    margin-top: 1rem;
    transition: background 0.2s, transform 0.2s;
  }

  .external-btn:hover {
    background: var(--accent-hover);
    transform: translateY(-1px);
  }
</style>
