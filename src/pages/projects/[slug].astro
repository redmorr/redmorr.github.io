---
import Layout from '../../layouts/Layout.astro';
import { projects } from '../../data/projects';

export function getStaticPaths() {
  return projects
    .filter(p => p.type !== 'placeholder')
    .map(p => ({ params: { slug: p.slug }, props: { project: p } }));
}

const { project } = Astro.props;
---

<Layout title={`${project.title} — redmorr`}>
  <a href="/" class="back">← Back</a>

  <article class="project">
    <header class="project-header">
      <span class="tag">{project.type === 'unity' ? 'Unity' : 'Blazor'}</span>
      <h1>{project.title}</h1>
      <p class="description">{project.longDescription}</p>
    </header>

    {project.thumbnail && (
      <div class="thumbnail">
        <img src={project.thumbnail} alt={project.title} />
      </div>
    )}

    {project.url && (
      <div class="cta">
        <a href={project.url} target="_blank" rel="noopener noreferrer" class="play-btn">
          {project.type === 'unity' ? 'Play in Browser' : 'Open App'} →
        </a>
      </div>
    )}
  </article>
</Layout>

<style>
  .back {
    display: inline-block;
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-bottom: 2.5rem;
    transition: color 0.15s;
  }

  .back:hover {
    color: var(--text);
  }

  .project {
    max-width: 720px;
  }

  .project-header {
    margin-bottom: 2rem;
  }

  .tag {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .description {
    font-size: 1.05rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  .thumbnail {
    margin-bottom: 2rem;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--border);
  }

  .thumbnail img {
    width: 100%;
    display: block;
  }

  .cta {
    margin-top: 2rem;
  }

  .play-btn {
    display: inline-block;
    background: var(--accent);
    color: #fff;
    font-weight: 600;
    font-size: 1rem;
    padding: 0.75rem 2rem;
    border-radius: 6px;
    transition: background 0.2s, transform 0.2s;
  }

  .play-btn:hover {
    background: var(--accent-hover);
    transform: translateY(-1px);
  }
</style>
